# Security-first ignore rules for a Spring Boot + React + Docker repository.
# Keep secrets, machine-local state, and generated artifacts out of Git.

# Environment and secret injection files.
# These files commonly contain API keys, DB URLs, JWT secrets, OAuth values, and per-machine settings.
.env
.env.*
*.env
*.env.*
!.env.example
!**/.env.example
!**/.env.*.example

# Local-only Spring Boot config overrides.
# These frequently hold production-like credentials and should stay on the developer machine only.
application-local.properties
application-local.yml
application-local.yaml
application-*.local.properties
application-*.local.yml
application-*.local.yaml
**/application-local.properties
**/application-local.yml
**/application-local.yaml
**/application-*.local.properties
**/application-*.local.yml
**/application-*.local.yaml

# Secrets, credentials, and private material directories.
# Use placeholder examples in Git instead of real secret stores.
secrets/
**/secrets/
credentials/
**/credentials/
private/
**/private/
certs/
**/certs/
certificates/
**/certificates/
ssl/
**/ssl/

# Certificates, keys, keystores, and signing material.
# These files can grant access directly and must never be committed.
*.pem
*.key
*.p8
*.pk8
*.crt
*.cer
*.csr
*.der
*.p7b
*.pfx
*.p12
*.jks
*.keystore
*.kdbx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Local auth helpers and shell-based secret loaders.
# These are easy to commit by accident and often contain tokens or secret exports.
.envrc
.direnv/
*.token
*.secret
*.secrets

# Logs, crash dumps, and runtime diagnostics.
# Logs often capture headers, request bodies, stack traces, and other sensitive runtime details.
logs/
log/
*.log
*.log.*
*.out
*.err
*.pid
*.pid.lock
*.seed
nohup.out
hs_err_pid*
replay_pid*
*.hprof

# Spring Boot / Gradle / JVM build outputs.
# Generated classes and packaged artifacts should be rebuilt, not versioned.
.gradle/
**/.gradle/
.gradle-user-home*/
backend/build/
backend/bin/
backend/out/
build/
**/build/
out/
**/out/
target/
*.class
*.jar
*.war
*.ear

# React / Node.js dependencies, caches, and build outputs.
# These are large, machine-specific, and reproducible from package manifests.
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
coverage/
**/coverage/
.parcel-cache/
.turbo/
.npm/
.pnpm-store/
.eslintcache
.stylelintcache
*.tsbuildinfo
.pnp.*
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Docker and container-local override files.
# Compose override files and local Docker folders often contain secret mounts, host paths, and machine-only settings.
.docker/
**/.docker/
docker-compose.override.yml
docker-compose.override.yaml
docker-compose.local.yml
docker-compose.local.yaml
docker-compose.*.local.yml
docker-compose.*.local.yaml
compose.override.yml
compose.override.yaml
*.cid
*.docker.env
.env.docker

# Local databases, caches, backups, and exports.
# These frequently contain real user or operational data and should stay out of source control.
*.sqlite
*.sqlite3
*.db
*.db-journal
*.rdb
*.bak
*.backup
*.tmp
*.temp
*.orig
*.rej
tmp/
temp/
backups/
dumps/
exports/

# IDE, editor, and OS metadata.
# Personal workspace settings should not leak machine paths, extensions, terminals, or local history.
.vscode/
.vscode-test/
.idea/
.fleet/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.factorypath
.metadata/
.history/
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# Deployment tool metadata downloaded per machine.
# Keep platform linkage local unless the team explicitly decides otherwise.
.vercel/

# Local prompt notes and request logs.
# These may include private operational context and should stay local.
docs/prompts/
