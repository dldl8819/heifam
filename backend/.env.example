# Spring Boot runtime
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/YOUR_DB_NAME
SPRING_DATASOURCE_USERNAME=YOUR_DB_USERNAME
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD
SPRING_DATASOURCE_SSLMODE=prefer
SPRING_DATASOURCE_MAX_POOL_SIZE=10
SPRING_DATASOURCE_MIN_IDLE=2

# Access control
ADMIN_EMAILS=YOUR_ADMIN_EMAILS
SUPER_ADMIN_EMAILS=YOUR_SUPER_ADMIN_EMAILS
ALLOWED_USER_EMAILS=YOUR_ALLOWED_USER_EMAILS

# External auth / verification
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_URL
AUTH_REQUIRE_JWT=true
AUTH_ALLOW_EMAIL_HEADER_FALLBACK=false
SUPABASE_VERIFY_TIMEOUT_MS=3000
SUPABASE_VERIFICATION_CACHE_TTL_SECONDS=15

# Upbit integration
UPBIT_ENABLED=false
UPBIT_BASE_URL=https://api.upbit.com
UPBIT_ACCESS_KEY=YOUR_API_KEY
UPBIT_SECRET_KEY=YOUR_SECRET_KEY

# Internal JWT issuance example
JWT_ENABLED=false
JWT_ISSUER=YOUR_JWT_ISSUER
JWT_SECRET=YOUR_SECRET_KEY
JWT_ACCESS_TOKEN_TTL=15m

# Application behavior
CORS_ALLOWED_ORIGINS=http://localhost:3000
ROOT_LOG_LEVEL=INFO
SPRING_SECURITY_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
RANK_DORMANCY_ENABLED=true
RANK_DORMANCY_INACTIVE_DAYS=30
RANK_DORMANCY_DEMOTE_STEPS=1
