<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.balancify.backend.logging.SensitiveDataMaskingPatternLayout">
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n%ex</pattern>
            </layout>
        </encoder>
    </appender>

    <root level="${ROOT_LOG_LEVEL:-INFO}">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="org.hibernate.SQL" level="WARN" />
    <logger name="org.hibernate.orm.jdbc.bind" level="OFF" />
    <logger name="org.springframework.web.filter.CommonsRequestLoggingFilter" level="OFF" />
</configuration>
