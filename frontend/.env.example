# Vercel production example
# Client requests use same-origin proxy (`/api/proxy`) by default in production.
# Optional: direct backend override for special cases.
NEXT_PUBLIC_API_BASE_URL=
# Server-side proxy target list (first reachable URL is used)
BACKEND_API_BASE_URLS=https://api.heifam.com,https://heifam.onrender.com
# Upstream timeout for proxy (ms): raise if Render cold starts are frequent.
BACKEND_PROXY_UPSTREAM_TIMEOUT_MS=25000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
NEXTAUTH_URL=https://www.heifam.co.kr
# Optional: restrict Google sign-in to specific member emails (comma-separated)
ALLOWED_SIGNIN_EMAILS=member1@example.com,member2@example.com
# Optional: allow full domain sign-in (comma-separated, e.g. heifam.com,gmail.com)
ALLOWED_SIGNIN_DOMAINS=
# Optional: sync signed-in user profile to Supabase `users` table (default off)
NEXT_PUBLIC_ENABLE_SUPABASE_PROFILE_SYNC=false
